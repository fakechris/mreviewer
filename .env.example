APP_ENV=development
PORT=3100
# 如果你使用默认 Docker Compose 部署，这两个值通常不需要改。
# compose 内的 ingress/worker 会自动使用 mysql:3306 和 redis:6379。
# 这里保留 127.0.0.1 版本，是为了你在宿主机直接执行 go run ./cmd/manual-trigger 时可直接复用。
MYSQL_DSN=mreviewer:mreviewer_password@tcp(127.0.0.1:3306)/mreviewer?parseTime=true&loc=UTC&charset=utf8mb4&collation=utf8mb4_unicode_ci
REDIS_ADDR=127.0.0.1:6380

# Docker Compose 默认会自动初始化下面这套 MySQL：
# - database: mreviewer
# - user: mreviewer
# - password: mreviewer_password
# - host from host machine: 127.0.0.1:3306
# 只有在你改 compose、改端口、或切外部 MySQL 时，才需要同步调整 MYSQL_DSN。

GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=replace-me
GITLAB_WEBHOOK_SECRET=replace-me
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=MiniMax-M2.7-highspeed
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=replace-me
GITHUB_WEBHOOK_SECRET=replace-me
REVIEW_PACKS=security,architecture,database
REVIEW_ADVISOR_ROUTE=
REVIEW_COMPARE_REVIEWERS=
# 多 provider 路由建议统一在 config.yaml 的 llm.routes 中配置。
# 当 ANTHROPIC_* 未设置时，worker 仍会回退到 MINIMAX_*：
# MINIMAX_API_KEY=replace-me
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Review 输出语言不走环境变量，默认是 zh-CN。
# 通过仓库内 .gitlab/ai-review.yaml 配置，例如：
# output_language: zh-CN
# output_language: en-US
