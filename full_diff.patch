+		        gitlab_discussion_id, error_code, created_at, updated_at
+		 FROM review_findings WHERE merge_request_id = ? AND gitlab_discussion_id = ? LIMIT 1`,
+		arg.MergeRequestID, arg.GitlabDiscussionID)
