# GitLab Configuration
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_WEBHOOK_SECRET=your_webhook_secret

# Single-provider quick-start contract
# Choose one of:
# - MiniMax:   LLM_PROVIDER=minimax
# - Anthropic: LLM_PROVIDER=anthropic
# - OpenAI:    LLM_PROVIDER=openai
LLM_PROVIDER=minimax
LLM_API_KEY=your_provider_api_key
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=MiniMax-M2.7-highspeed

# Quick-start examples:
# MiniMax
#   LLM_PROVIDER=minimax
#   LLM_BASE_URL=https://api.minimaxi.com/anthropic
#   LLM_MODEL=MiniMax-M2.7-highspeed
# Anthropic
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-sonnet-4-6
# ChatGPT / OpenAI
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-5.4

# Legacy / advanced provider envs (optional)
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Advanced config path (optional, used by config.example.yaml)
MREVIEWER_INGRESS_IMAGE=fakechris/mreviewer-ingress:main
MREVIEWER_WORKER_IMAGE=fakechris/mreviewer-worker:main
MINIMAX_GROUP_ID=your_minimax_group_id

# Database (optional, defaults provided)
MYSQL_PASSWORD=mreviewer_password
MYSQL_ROOT_PASSWORD=root_password

# Ports (optional)
PORT=3100
MYSQL_PORT=3306
REDIS_PORT=6380
